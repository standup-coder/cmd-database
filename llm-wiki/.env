# LLM-Wiki Configuration
# Following Ar9av/obsidian-wiki spec

# Vault location
OBSIDIAN_VAULT_PATH="/Users/allengaller/Documents/GitHub/standup-coder/cmd4coder/llm-wiki"

# Source documents directory (where raw materials live)
OBSIDIAN_SOURCES_DIR="/Users/allengaller/Documents/GitHub/standup-coder/cmd4coder/data"

# Claude history path (optional, for history ingestion)
CLAUDE_HISTORY_PATH="/Users/allengaller/.claude"

# Link format: wikilink | markdown
OBSIDIAN_LINK_FORMAT="wikilink"

# Staged writes: true = new pages go to _staging/ first
WIKI_STAGED_WRITES="false"

# Token budget warning threshold (0 = disabled)
WIKI_TOKEN_WARN_THRESHOLD="100000"

# Output language
WIKI_OUTPUT_LANGUAGE="zh"

# QMD Semantic Search (optional)
# QMD_WIKI_COLLECTION="llm-wiki"
# QMD_TRANSPORT="mcp"
# QMD_CLI_SEARCH_MODE="quality"
